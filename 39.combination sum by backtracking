class Solution {
        public static void func(int[] candidates,int index, List<List<Integer>> ans, int target, List<Integer>subList) {
            if(target == 0){
                ans.add(new ArrayList<>(subList));
                return;
            }
            if (index == candidates.length || target <0){
                return;
            }
            subList.add(candidates[index]);
            func(candidates,index,ans,target - candidates[index],subList);
            subList.remove(subList.size() - 1 );
            func(candidates,index+1,ans,target,subList);
        }
        public List<List<Integer>> combinationSum(int[] candidates, int target){
            List<List<Integer>> ans = new ArrayList<>();
            func(candidates,0,ans,target,new ArrayList<>());
            return ans;
        
    }
}
