class Main {
   public static int climbstairs(int n) {
       
       if(n < 2){
           return 1;
           
       }
       
       
       return climbstairs(n - 1)+ climbstairs(n - 2);
   }
       
       
    
    public static void main(String[] args){
        System.out.println(climbstairs(3));
    }
}
