class Main {
   public static int binarystring(int n) {
       
       if(n == 0){
           return 1;
           
       }
       if (n == 1){
           return 2;
       }
       return binarystring(n - 1)+ binarystring(n - 2);
       
       
       
    }
    public static void main(String[] args){
        System.out.println(binarystring(6));
    }
}
